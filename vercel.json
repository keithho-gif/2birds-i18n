{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/compliance", "destination": "/audit", "permanent": true },
    { "source": "/compliance.html", "destination": "/audit", "permanent": true },
    { "source": "/marketing", "destination": "/revenue", "permanent": true },
    { "source": "/marketing.html", "destination": "/revenue", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval'; img-src 'self' data: https: https://flagcdn.com; media-src 'self' https: blob:; frame-src https:;"
        }
      ]
    }
  ]
}
